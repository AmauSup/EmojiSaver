{
  "manifest_version": 2,
  "name": "Discord Emoji Extractor",
  "version": "1.0",
  "description": "Extract custom Discord emojis from visible UI",

  "permissions": [
    "storage",
    "clipboardWrite",
    "https://discord.com/*"
  ],

  "background": {
    "scripts": ["background.js"]
  },

  "content_scripts": [
    {
      "matches": ["*://discord.com/*"],
      "js": [
        "utilis/regex.js",
        "content/domScanner.js",
        "content/emojiExtractor.js",
        "content/discordObserver.js"
      ],
      "run_at": "document_idle"
    }
  ],

  "browser_action": {
    "default_title": "Discord Emoji Extractor",
    "default_popup": "popup/popup.html"
  }
}
